{
  "openapi": "3.0.0",
  "info": {
    "title": "PoYo AI - Sora 2 Beta API",
    "description": "Text-to-video and optional image-guided video generation",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.poyo.ai",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/api/generate/submit": {
      "post": {
        "summary": "Submit Sora 2 Beta Task",
        "description": "Generate videos with Sora 2 Beta",
        "operationId": "submitSora2BetaTask",
        "tags": ["Sora 2 Beta"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitRequest"
              },
              "examples": {
                "sora-2-beta-text-to-video": {
                  "summary": "Sora 2 Beta Text-to-Video",
                  "value": {
                    "model": "sora-2-beta",
                    "callback_url": "https://your-domain.com/callback",
                    "input": {
                      "prompt": "A cinematic shot of a red sports car driving through neon rain at night, reflective streets, dramatic lighting, smooth camera tracking.",
                      "duration": 8,
                      "aspect_ratio": "16:9"
                    }
                  }
                },
                "sora-2-beta-image-to-video": {
                  "summary": "Sora 2 Beta Image-to-Video",
                  "value": {
                    "model": "sora-2-beta",
                    "input": {
                      "prompt": "Animate this image into a smooth cinematic video with natural motion and soft camera movement.",
                      "duration": 4,
                      "aspect_ratio": "9:16",
                      "image_urls": ["https://example.com/reference-image.png"]
                    }
                  }
                },
                "sora-2-beta-image-to-video-base64": {
                  "summary": "Sora 2 Beta Image-to-Video with Base64 Image",
                  "value": {
                    "model": "sora-2-beta",
                    "input": {
                      "prompt": "Animate this image into a smooth cinematic video with natural motion and soft camera movement.",
                      "duration": 4,
                      "aspect_ratio": "16:9",
                      "image_urls": ["data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAA..."]
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmitResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API Key",
        "description": "All API endpoints require Bearer Token authentication\n\nGet your API Key:\n\nVisit the [API Key Management Page](https://poyo.ai/dashboard/api-key) to get your API Key\n\nAdd it to the request header:\n\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    },
    "schemas": {
      "SubmitRequest": {
        "type": "object",
        "required": ["model", "input"],
        "properties": {
          "model": {
            "type": "string",
            "description": "Sora 2 Beta model identifier",
            "enum": ["sora-2-beta"]
          },
          "callback_url": {
            "type": "string",
            "format": "uri",
            "description": "Webhook callback URL for result notifications",
            "example": "https://your-domain.com/callback"
          },
          "input": {
            "type": "object",
            "required": ["prompt"],
            "properties": {
              "prompt": {
                "type": "string",
                "description": "Generation prompt describing the desired video",
                "example": "A cinematic shot of a red sports car driving through neon rain at night, reflective streets, dramatic lighting, smooth camera tracking."
              },
              "duration": {
                "type": "integer",
                "description": "Output duration in seconds",
                "enum": [4, 8, 12],
                "default": 4,
                "example": 8
              },
              "aspect_ratio": {
                "type": "string",
                "description": "Video aspect ratio",
                "enum": ["16:9", "9:16"],
                "default": "16:9",
                "example": "16:9"
              },
              "image_urls": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "maxItems": 1,
                "description": "Optional reference image array for image-to-video generation. If provided, exactly one image is used as the first frame/reference image. Supports HTTP(S) image URLs or base64 image strings, including data:image/...;base64,... values.",
                "example": ["https://example.com/reference-image.png"]
              }
            }
          }
        }
      },
      "SubmitResponse": {
        "type": "object",
        "required": ["code", "data"],
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "data": {
            "type": "object",
            "required": ["task_id", "status", "created_time"],
            "properties": {
              "task_id": {
                "type": "string",
                "example": "task-unified-1757165031-uyujaw3d"
              },
              "status": {
                "type": "string",
                "enum": ["not_started"],
                "example": "not_started"
              },
              "created_time": {
                "type": "string",
                "format": "date-time",
                "example": "2025-11-12T10:30:00"
              }
            }
          }
        }
      }
    }
  }
}
