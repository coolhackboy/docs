{
  "openapi": "3.0.0",
  "info": {
    "title": "PoYo AI - Kling 3.0 Turbo API",
    "description": "Fast video generation with Kling 3.0 Turbo standard and pro models",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.poyo.ai",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/api/generate/submit": {
      "post": {
        "summary": "Submit Kling 3.0 Turbo Video Generation Task",
        "description": "Generate videos using Kling 3.0 Turbo. If input.image_urls is provided, the request is routed to image-to-video; otherwise it is routed to text-to-video.",
        "operationId": "submitKling30TurboTask",
        "tags": ["Kling 3.0 Turbo"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitRequest"
              },
              "examples": {
                "standardText": {
                  "summary": "Kling 3.0 Turbo Standard - Text to Video",
                  "value": {
                    "model": "kling-3.0-turbo/standard",
                    "callback_url": "https://your-domain.com/callback",
                    "input": {
                      "prompt": "A chef carefully plating a gourmet dish in a modern kitchen, steam rising from the food under warm lighting",
                      "duration": 5,
                      "aspect_ratio": "16:9"
                    }
                  }
                },
                "proImage": {
                  "summary": "Kling 3.0 Turbo Pro - Image to Video",
                  "value": {
                    "model": "kling-3.0-turbo/pro",
                    "callback_url": "https://your-domain.com/callback",
                    "input": {
                      "prompt": "The portrait subject softly smiles as the camera pushes in, cinematic light moving across the face",
                      "image_urls": ["https://example.com/first-frame.png"],
                      "duration": 5
                    }
                  }
                },
                "multiPrompt": {
                  "summary": "Kling 3.0 Turbo - Multi-Shot",
                  "value": {
                    "model": "kling-3.0-turbo/standard",
                    "input": {
                      "multi_prompt": [
                        {
                          "prompt": "A surfer paddling out into the ocean as waves build on the horizon",
                          "duration": 4
                        },
                        {
                          "prompt": "The surfer catches a massive wave and rides toward shore at sunset",
                          "duration": 4
                        }
                      ],
                      "duration": 8,
                      "aspect_ratio": "16:9"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmitResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API Key",
        "description": "All API endpoints require Bearer Token authentication.\n\nGet your API Key from the API Key Management page, then add it to the request header:\n\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    },
    "schemas": {
      "SubmitRequest": {
        "type": "object",
        "required": ["model", "input"],
        "properties": {
          "model": {
            "type": "string",
            "description": "Kling 3.0 Turbo model identifier",
            "enum": [
              "kling-3.0-turbo/standard",
              "kling-3.0-turbo/pro"
            ],
            "example": "kling-3.0-turbo/standard"
          },
          "callback_url": {
            "type": "string",
            "format": "uri",
            "description": "Webhook callback URL for result notifications",
            "example": "https://your-domain.com/callback"
          },
          "input": {
            "type": "object",
            "description": "Input parameters for generation. If image_urls has a value, image_urls[0] is used as the first-frame image and the request is routed to image-to-video.",
            "properties": {
              "prompt": {
                "type": "string",
                "description": "Video generation prompt. Mutually exclusive with multi_prompt.",
                "maxLength": 2500,
                "example": "A street musician playing violin on a rainy evening, reflections shimmering on wet cobblestones"
              },
              "multi_prompt": {
                "type": "array",
                "description": "Multi-shot storyboard. Mutually exclusive with prompt. Total duration must not exceed 15 seconds.",
                "minItems": 1,
                "maxItems": 6,
                "items": {
                  "type": "object",
                  "required": ["prompt"],
                  "properties": {
                    "prompt": {
                      "type": "string",
                      "description": "Prompt text for this shot",
                      "maxLength": 2500
                    },
                    "duration": {
                      "type": "integer",
                      "description": "Duration in seconds for this shot. Defaults to 5 if omitted.",
                      "minimum": 1,
                      "maximum": 15,
                      "example": 4
                    }
                  }
                }
              },
              "image_urls": {
                "type": "array",
                "description": "Optional first-frame image URL array. Only one image is supported, and image_urls[0] is sent as image_url.",
                "maxItems": 1,
                "items": {
                  "type": "string",
                  "format": "uri"
                },
                "example": ["https://example.com/first-frame.png"]
              },
              "duration": {
                "type": "integer",
                "description": "Video duration in seconds. Defaults to 5 if omitted. When multi_prompt is used, this must equal the total multi_prompt duration if provided.",
                "minimum": 3,
                "maximum": 15,
                "default": 5,
                "example": 5
              },
              "aspect_ratio": {
                "type": "string",
                "description": "Video aspect ratio for text-to-video mode. Not supported when image_urls is provided.",
                "enum": ["16:9", "9:16", "1:1"],
                "default": "16:9",
                "example": "16:9"
              }
            }
          }
        }
      },
      "SubmitResponse": {
        "type": "object",
        "required": ["code", "data"],
        "properties": {
          "code": {
            "type": "integer",
            "example": 200,
            "description": "HTTP status code"
          },
          "data": {
            "type": "object",
            "required": ["task_id", "status", "created_time"],
            "properties": {
              "task_id": {
                "type": "string",
                "example": "task-unified-1757165031-uyujaw3d",
                "description": "Unique task identifier for status tracking"
              },
              "status": {
                "type": "string",
                "enum": ["not_started"],
                "example": "not_started",
                "description": "Initial task status"
              },
              "created_time": {
                "type": "string",
                "format": "date-time",
                "example": "2025-11-12T10:30:00",
                "description": "ISO 8601 timestamp when the task was created"
              }
            }
          }
        }
      }
    }
  }
}
