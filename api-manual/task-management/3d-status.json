{
  "openapi": "3.1.0",
  "info": {
    "title": "PoYo AI - 3D Task Status API",
    "description": "Query 3D task execution status and retrieve generated model files",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.poyo.ai"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/api/generate/status/{task_id}": {
      "get": {
        "summary": "Query 3D Task Status",
        "operationId": "queryThreeDTaskStatus",
        "tags": [
          "3D Task Management"
        ],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique task identifier returned from the submit endpoint"
          }
        ],
        "responses": {
          "200": {
            "description": "Task status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                },
                "examples": {
                  "finished": {
                    "summary": "Finished 3D task",
                    "value": {
                      "code": 200,
                      "data": {
                        "task_id": "task-unified-1757165031-uyujaw3d",
                        "status": "finished",
                        "files": [
                          {
                            "label": "model_glb",
                            "file_url": "https://storage.poyo.ai/generated/model.glb",
                            "file_type": "model",
                            "format": "glb",
                            "content_type": "model/gltf-binary",
                            "file_name": "model.glb",
                            "file_size": 43803144
                          },
                          {
                            "label": "thumbnail",
                            "file_url": "https://storage.poyo.ai/generated/thumbnail.png",
                            "file_type": "image",
                            "format": "png",
                            "content_type": "image/png",
                            "file_name": "thumbnail.png",
                            "file_size": 312445
                          }
                        ],
                        "metadata": {},
                        "created_time": "2025-11-12T10:30:00",
                        "progress": 100,
                        "error_message": null
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API Key"
      }
    },
    "schemas": {
      "StatusResponse": {
        "type": "object",
        "required": [
          "code",
          "data"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "data": {
            "$ref": "#/components/schemas/TaskStatus"
          }
        }
      },
      "TaskStatus": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "not_started",
              "running",
              "finished",
              "failed"
            ],
            "example": "finished"
          },
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FileItem"
            }
          },
          "metadata": {
            "type": "object",
            "description": "Reserved metadata object. Processed 3D outputs are usually returned in files.",
            "additionalProperties": true
          },
          "created_time": {
            "type": "string",
            "format": "date-time"
          },
          "progress": {
            "type": "number",
            "example": 100
          },
          "error_message": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "FileItem": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "example": "model_glb"
          },
          "file_url": {
            "type": "string",
            "format": "uri"
          },
          "file_type": {
            "type": "string",
            "enum": [
              "model",
              "image",
              "file"
            ]
          },
          "format": {
            "type": "string",
            "example": "glb"
          },
          "content_type": {
            "type": "string",
            "example": "model/gltf-binary"
          },
          "file_name": {
            "type": "string",
            "example": "model.glb"
          },
          "file_size": {
            "type": "integer",
            "example": 43803144
          }
        }
      }
    }
  }
}
