{
  "openapi": "3.1.0",
  "info": {
    "title": "PoYo AI - 3D Task Status API",
    "description": "Query 3D task execution status and retrieve generated model files",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.poyo.ai"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/api/generate/status/{task_id}": {
      "get": {
        "summary": "Query 3D Task Status",
        "operationId": "queryThreeDTaskStatus",
        "tags": [
          "3D Task Management"
        ],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique task identifier returned from the submit endpoint"
          }
        ],
        "responses": {
          "200": {
            "description": "Task status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                },
                "examples": {
                  "finished": {
                    "summary": "Finished 3D task",
                    "value": {
                      "code": 200,
                      "data": {
                        "task_id": "9OTM0HH9LBS63LF0",
                        "status": "finished",
                        "files": [
                          {
                            "file_url": "https://cdn.doculator.org/3d/9OTM0HH9LBS63LF0/9OTM0HH9LBS63LF0_1.glb",
                            "file_type": "3d"
                          },
                          {
                            "file_url": "https://cdn.doculator.org/3d/9OTM0HH9LBS63LF0/9OTM0HH9LBS63LF0_2.png",
                            "file_type": "image"
                          },
                          {
                            "file_url": "https://cdn.doculator.org/3d/9OTM0HH9LBS63LF0/9OTM0HH9LBS63LF0_3.glb",
                            "file_type": "3d"
                          }
                        ],
                        "created_time": "2026-05-12T02:36:12",
                        "progress": 100
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API Key"
      }
    },
    "schemas": {
      "StatusResponse": {
        "type": "object",
        "required": [
          "code",
          "data"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "data": {
            "$ref": "#/components/schemas/TaskStatus"
          }
        },
        "example": {
          "code": 200,
          "data": {
            "task_id": "9OTM0HH9LBS63LF0",
            "status": "finished",
            "files": [
              {
                "file_url": "https://cdn.doculator.org/3d/9OTM0HH9LBS63LF0/9OTM0HH9LBS63LF0_1.glb",
                "file_type": "3d"
              },
              {
                "file_url": "https://cdn.doculator.org/3d/9OTM0HH9LBS63LF0/9OTM0HH9LBS63LF0_2.png",
                "file_type": "image"
              },
              {
                "file_url": "https://cdn.doculator.org/3d/9OTM0HH9LBS63LF0/9OTM0HH9LBS63LF0_3.glb",
                "file_type": "3d"
              }
            ],
            "created_time": "2026-05-12T02:36:12",
            "progress": 100
          }
        }
      },
      "TaskStatus": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "not_started",
              "running",
              "finished",
              "failed"
            ],
            "example": "finished"
          },
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FileItem"
            }
          },
          "created_time": {
            "type": "string",
            "format": "date-time"
          },
          "progress": {
            "type": "number",
            "example": 100
          },
          "error_message": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "example": {
          "task_id": "9OTM0HH9LBS63LF0",
          "status": "finished",
          "files": [
            {
              "file_url": "https://cdn.doculator.org/3d/9OTM0HH9LBS63LF0/9OTM0HH9LBS63LF0_1.glb",
              "file_type": "3d"
            },
            {
              "file_url": "https://cdn.doculator.org/3d/9OTM0HH9LBS63LF0/9OTM0HH9LBS63LF0_2.png",
              "file_type": "image"
            },
            {
              "file_url": "https://cdn.doculator.org/3d/9OTM0HH9LBS63LF0/9OTM0HH9LBS63LF0_3.glb",
              "file_type": "3d"
            }
          ],
          "created_time": "2026-05-12T02:36:12",
          "progress": 100
        }
      },
      "FileItem": {
        "type": "object",
        "required": [
          "file_url",
          "file_type"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Optional file label when provided by the model"
          },
          "file_url": {
            "type": "string",
            "format": "uri",
            "example": "https://cdn.doculator.org/3d/9OTM0HH9LBS63LF0/9OTM0HH9LBS63LF0_1.glb"
          },
          "file_type": {
            "type": "string",
            "enum": [
              "3d",
              "image",
              "other"
            ],
            "example": "3d"
          },
          "format": {
            "type": "string",
            "description": "Optional file format when provided by the model"
          },
          "content_type": {
            "type": "string",
            "description": "Optional MIME type when provided by the model"
          },
          "file_name": {
            "type": "string",
            "description": "Optional file name when provided by the model"
          },
          "file_size": {
            "type": "integer",
            "description": "Optional file size in bytes when provided by the model"
          }
        },
        "example": {
          "file_url": "https://cdn.doculator.org/3d/9OTM0HH9LBS63LF0/9OTM0HH9LBS63LF0_1.glb",
          "file_type": "3d"
        }
      }
    }
  }
}
