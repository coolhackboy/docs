{
  "openapi": "3.0.0",
  "info": {
    "title": "Claude Messages API",
    "description": "Anthropic Messages-compatible endpoint for Claude models.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.poyo.ai",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": [],
      "AnthropicVersion": []
    }
  ],
  "paths": {
    "/v1/messages": {
      "post": {
        "summary": "Claude Messages API",
        "description": "Send requests in the Claude Messages format. For the latest request parameter definitions, refer to the official Anthropic documentation: https://platform.claude.com/docs/en/api/messages/create",
        "operationId": "createClaudeMessage",
        "tags": [
          "Text Series"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClaudeMessageRequest"
              },
              "examples": {
                "basic": {
                  "summary": "Basic Claude message",
                  "value": {
                    "model": "claude-sonnet-4-5-20250929",
                    "max_tokens": 1024,
                    "messages": [
                      {
                        "role": "user",
                        "content": "Rewrite the following product announcement to be more gentle and user-friendly: We will have maintenance for 2 hours this weekend, services will be unavailable during this time."
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClaudeMessageResponse"
                },
                "examples": {
                  "success": {
                    "summary": "Successful response",
                    "value": {
                      "code": 200,
                      "data": {
                        "id": "msg_013zva2CMHNLnXJNN3QKQ2EF",
                        "type": "message",
                        "role": "assistant",
                        "content": [
                          {
                            "type": "text",
                            "text": "Hello! I'm Claude. Nice to meet you."
                          }
                        ],
                        "model": "claude-sonnet-4-5-20250929",
                        "stop_reason": "end_turn",
                        "stop_sequence": null,
                        "usage": {
                          "input_tokens": 10,
                          "output_tokens": 13
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key for authentication.\n\nVisit the API Key Management Page to get your API Key\n\nAdd to the request header:\n\n```\nx-api-key: YOUR_API_KEY\n```"
      },
      "AnthropicVersion": {
        "type": "apiKey",
        "in": "header",
        "name": "anthropic-version",
        "description": "API version. Example: `2025-10-01`."
      }
    },
    "schemas": {
      "ClaudeMessageRequest": {
        "type": "object",
        "required": [
          "model",
          "max_tokens",
          "messages"
        ],
        "properties": {
          "model": {
            "type": "string",
            "description": "Claude model name.",
            "example": "claude-sonnet-4-5-20250929"
          },
          "messages": {
            "type": "array",
            "description": "Conversation messages in order. Example: [{\"role\": \"user\", \"content\": \"Summarize the purpose of feature canary releases in two sentences.\"}].",
            "items": {
              "$ref": "#/components/schemas/ClaudeMessage"
            }
          },
          "max_tokens": {
            "type": "integer",
            "minimum": 1,
            "description": "Maximum tokens to generate.",
            "example": 1024
          },
          "system": {
            "description": "System prompt for the assistant.",
            "oneOf": [
              {
                "type": "string",
                "example": "You are a product announcement editor, keep it objective and concise."
              },
              {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ClaudeContentBlock"
                }
              }
            ]
          },
          "cache_control": {
            "$ref": "#/components/schemas/ClaudeCacheControl"
          },
          "stream": {
            "type": "boolean",
            "description": "Enable streaming responses.",
            "example": false
          },
          "stop_sequences": {
            "type": "array",
            "description": "Stop sequences. The model stops when it encounters any of these strings.",
            "items": {
              "type": "string"
            }
          },
          "metadata": {
            "type": "object",
            "description": "Additional metadata such as `user_id`.",
            "additionalProperties": true
          },
          "output_config": {
            "$ref": "#/components/schemas/ClaudeOutputConfig"
          },
          "thinking": {
            "description": "Configuration for enabling Claude's extended thinking.",
            "oneOf": [
              {
                "$ref": "#/components/schemas/ClaudeThinkingEnabled"
              },
              {
                "$ref": "#/components/schemas/ClaudeThinkingAdaptive"
              },
              {
                "$ref": "#/components/schemas/ClaudeThinkingDisabled"
              }
            ]
          },
          "tools": {
            "type": "array",
            "description": "Tool definitions available to the model.",
            "items": {
              "$ref": "#/components/schemas/ClaudeTool"
            }
          },
          "tool_choice": {
            "description": "Controls tool usage behavior.",
            "oneOf": [
              {
                "type": "string",
                "example": "auto"
              },
              {
                "type": "object",
                "additionalProperties": true
              }
            ]
          }
        }
      },
      "ClaudeMessage": {
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ],
            "description": "Role of the message author.",
            "example": "user"
          },
          "content": {
            "description": "Message content. Supports text or structured blocks.",
            "oneOf": [
              {
                "type": "string",
                "example": "Summarize the purpose of feature canary releases in two sentences."
              },
              {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ClaudeContentBlock"
                }
              }
            ]
          }
        }
      },
      "ClaudeTool": {
        "type": "object",
        "required": [
          "name",
          "input_schema"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "get_weather"
          },
          "description": {
            "type": "string",
            "example": "Fetch the weather by city name."
          },
          "input_schema": {
            "type": "object",
            "description": "JSON Schema for tool inputs.",
            "additionalProperties": true
          }
        }
      },
      "ClaudeCacheControl": {
        "type": "object",
        "description": "Top-level cache control automatically applies a cache_control marker to the last cacheable block in the request.",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "ephemeral"
            ],
            "description": "Cache control type.",
            "example": "ephemeral"
          },
          "ttl": {
            "type": "string",
            "enum": [
              "5m",
              "1h"
            ],
            "description": "Optional cache TTL. Defaults to `5m`.",
            "example": "1h"
          }
        }
      },
      "ClaudeOutputConfig": {
        "type": "object",
        "description": "Configuration options for the model's output, such as the output format.",
        "properties": {
          "effort": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "max"
            ],
            "description": "Output effort level.",
            "example": "high"
          },
          "format": {
            "$ref": "#/components/schemas/ClaudeOutputFormat"
          }
        }
      },
      "ClaudeOutputFormat": {
        "type": "object",
        "description": "Schema-based structured output configuration.",
        "required": [
          "type",
          "schema"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "json_schema"
            ],
            "example": "json_schema"
          },
          "schema": {
            "type": "object",
            "description": "JSON Schema that defines the output format.",
            "additionalProperties": true
          }
        }
      },
      "ClaudeThinkingEnabled": {
        "type": "object",
        "description": "Enabled extended thinking. Requires `budget_tokens` >= 1024 and less than `max_tokens`.",
        "required": [
          "type",
          "budget_tokens"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "enabled"
            ],
            "example": "enabled"
          },
          "budget_tokens": {
            "type": "integer",
            "minimum": 1024,
            "description": "Token budget for Claude's internal reasoning process.",
            "example": 2048
          },
          "display": {
            "type": "string",
            "enum": [
              "summarized",
              "omitted"
            ],
            "description": "Controls how thinking content appears in the response. Defaults to `summarized`.",
            "example": "summarized"
          }
        }
      },
      "ClaudeThinkingAdaptive": {
        "type": "object",
        "description": "Adaptive extended thinking configuration.",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "adaptive"
            ],
            "example": "adaptive"
          },
          "display": {
            "type": "string",
            "enum": [
              "summarized",
              "omitted"
            ],
            "description": "Controls how thinking content appears in the response. Defaults to `summarized`.",
            "example": "omitted"
          }
        }
      },
      "ClaudeThinkingDisabled": {
        "type": "object",
        "description": "Disable extended thinking.",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "disabled"
            ],
            "example": "disabled"
          }
        }
      },
      "ClaudeMessageResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "data": {
            "$ref": "#/components/schemas/ClaudeMessageResult"
          }
        }
      },
      "ClaudeMessageResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "msg_013zva2CMHNLnXJNN3QKQ2EF"
          },
          "type": {
            "type": "string",
            "example": "message"
          },
          "role": {
            "type": "string",
            "example": "assistant"
          },
          "content": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ClaudeContentBlock"
            }
          },
          "model": {
            "type": "string",
            "example": "claude-sonnet-4-5-20250929"
          },
          "stop_reason": {
            "type": "string",
            "example": "end_turn"
          },
          "stop_sequence": {
            "nullable": true,
            "type": "string"
          },
          "usage": {
            "$ref": "#/components/schemas/ClaudeUsage"
          }
        }
      },
      "ClaudeContentBlock": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "example": "text"
          },
          "text": {
            "type": "string",
            "description": "Text content for text blocks.",
            "example": "Hello! I'm Claude. Nice to meet you."
          },
          "source": {
            "type": "object",
            "description": "Source for image blocks.",
            "properties": {
              "type": {
                "type": "string",
                "example": "base64"
              },
              "media_type": {
                "type": "string",
                "example": "image/png"
              },
              "data": {
                "type": "string",
                "description": "Base64-encoded image data."
              },
              "url": {
                "type": "string",
                "description": "Image URL (if using URL source)."
              }
            }
          }
        }
      },
      "ClaudeUsage": {
        "type": "object",
        "properties": {
          "input_tokens": {
            "type": "integer",
            "example": 10
          },
          "output_tokens": {
            "type": "integer",
            "example": 13
          }
        }
      }
    }
  }
}
