{
  "openapi": "3.0.0",
  "info": {
    "title": "PoYo AI - ElevenLabs Music API",
    "description": "Generate studio-grade music from prompts or structured composition plans using ElevenLabs Music. PoYo pricing is $0.64 per started minute, equal to 128 credits per started minute.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.poyo.ai",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/api/generate/submit": {
      "post": {
        "summary": "Submit ElevenLabs Music Task",
        "description": "Generate music from a prompt or a structured composition plan.",
        "operationId": "submitElevenLabsMusicTask",
        "tags": ["ElevenLabs Music"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitRequest"
              },
              "examples": {
                "prompt-instrumental-score": {
                  "summary": "Prompt Instrumental Score",
                  "value": {
                    "model": "elevenlabs-music",
                    "callback_url": "https://your-domain.com/callback",
                    "input": {
                      "prompt": "A polished instrumental cinematic game menu loop for a neon sci-fi strategy game, elegant synth arpeggios, warm analog pads, restrained percussion, gradual heroic lift, no vocals, seamless background score.",
                      "duration": 45,
                      "is_instrumental": true,
                      "output_format": "opus_48000_128"
                    }
                  }
                },
                "prompt-vocal-multilingual-song": {
                  "summary": "Prompt Vocal Multilingual Song",
                  "value": {
                    "model": "elevenlabs-music",
                    "callback_url": "https://your-domain.com/callback",
                    "input": {
                      "prompt": "A studio-grade upbeat pop song with a clear vocal hook for a travel campaign, bright drums, warm bass, polished lead vocal, and a short bilingual English and Spanish refrain: 'We chase the sunrise' and 'Vamos hacia la luz'.",
                      "duration": 30,
                      "output_format": "mp3_44100_128"
                    }
                  }
                },
                "composition-plan-structured-song": {
                  "summary": "Composition Plan Structured Song",
                  "value": {
                    "model": "elevenlabs-music",
                    "callback_url": "https://your-domain.com/callback",
                    "input": {
                      "composition_plan": {
                        "positive_global_styles": [
                          "studio-grade pop production",
                          "clear multilingual vocal hook",
                          "cinematic electronic texture"
                        ],
                        "negative_global_styles": [
                          "muddy mix",
                          "harsh distortion",
                          "off-key vocals"
                        ],
                        "sections": [
                          {
                            "section_name": "Intro",
                            "positive_local_styles": [
                              "soft piano motif",
                              "wide atmospheric pads"
                            ],
                            "negative_local_styles": [
                              "heavy drums"
                            ],
                            "duration": 20,
                            "lines": [
                              "City lights awaken softly"
                            ]
                          },
                          {
                            "section_name": "Verse",
                            "positive_local_styles": [
                              "gentle vocal lead",
                              "subtle electronic pulse"
                            ],
                            "negative_local_styles": [
                              "crowded arrangement"
                            ],
                            "duration": 25,
                            "lines": [
                              "We cross the night with open eyes",
                              "Cada paso brilla bajo el cielo"
                            ]
                          },
                          {
                            "section_name": "Chorus",
                            "positive_local_styles": [
                              "anthemic hook",
                              "wide drums",
                              "bright layered vocals"
                            ],
                            "negative_local_styles": [
                              "thin bass"
                            ],
                            "duration": 30,
                            "lines": [
                              "Raise the signal, let it shine",
                              "We are the echo in the skyline"
                            ]
                          }
                        ]
                      },
                      "respect_sections_durations": true,
                      "output_format": "mp3_44100_128"
                    }
                  }
                },
                "short-brand-sonic-logo-format": {
                  "summary": "Short Brand Sonic Logo Format",
                  "value": {
                    "model": "elevenlabs-music",
                    "callback_url": "https://your-domain.com/callback",
                    "input": {
                      "prompt": "A concise instrumental sonic logo for a premium productivity app, five-note memorable motif, clean mallet attack, soft synth shimmer, confident but friendly ending, no vocals.",
                      "duration": 10,
                      "is_instrumental": true,
                      "output_format": "ulaw_8000"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmitResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API Key",
        "description": "All API endpoints require Bearer Token authentication.\n\nGet your API Key from the [API Key Management Page](https://poyo.ai/dashboard/api-key).\n\nAdd it to the request header:\n\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    },
    "schemas": {
      "SubmitRequest": {
        "type": "object",
        "required": ["model", "input"],
        "properties": {
          "model": {
            "type": "string",
            "description": "Model identifier.",
            "enum": ["elevenlabs-music"],
            "example": "elevenlabs-music"
          },
          "callback_url": {
            "type": "string",
            "format": "uri",
            "description": "Webhook callback URL for result notifications",
            "example": "https://your-domain.com/callback"
          },
          "input": {
            "$ref": "#/components/schemas/Input",
            "description": "Input parameters. Provide exactly one of prompt or composition_plan."
          }
        }
      },
      "Input": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Text prompt describing the music to generate. Required when composition_plan is not provided. Do not send prompt and composition_plan together.",
            "example": "A polished instrumental cinematic game menu loop for a neon sci-fi strategy game, elegant synth arpeggios, warm analog pads, restrained percussion, gradual heroic lift, no vocals, seamless background score."
          },
          "composition_plan": {
            "$ref": "#/components/schemas/CompositionPlan",
            "description": "Structured composition plan. Required when prompt is not provided. Do not send prompt and composition_plan together."
          },
          "duration": {
            "type": "number",
            "minimum": 3,
            "maximum": 600,
            "description": "Optional song length in seconds. Only valid with prompt.",
            "example": 45
          },
          "is_instrumental": {
            "type": "boolean",
            "description": "When true, requests instrumental-only output. Only valid with prompt.",
            "default": false,
            "example": true
          },
          "respect_sections_durations": {
            "type": "boolean",
            "description": "Controls how strictly section durations are enforced. Only valid with composition_plan.",
            "default": true,
            "example": true
          },
          "output_format": {
            "$ref": "#/components/schemas/OutputFormat"
          }
        }
      },
      "CompositionPlan": {
        "type": "object",
        "required": ["positive_global_styles", "negative_global_styles", "sections"],
        "additionalProperties": false,
        "properties": {
          "positive_global_styles": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Global styles to include.",
            "example": ["studio-grade pop production", "clear multilingual vocal hook", "cinematic electronic texture"]
          },
          "negative_global_styles": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Global styles to avoid.",
            "example": ["muddy mix", "harsh distortion", "off-key vocals"]
          },
          "sections": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/CompositionSection"
            }
          }
        }
      },
      "CompositionSection": {
        "type": "object",
        "required": ["section_name", "positive_local_styles", "negative_local_styles", "duration", "lines"],
        "additionalProperties": false,
        "properties": {
          "section_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Section name.",
            "example": "Verse"
          },
          "positive_local_styles": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Section-specific styles to include.",
            "example": ["gentle vocal lead", "subtle electronic pulse"]
          },
          "negative_local_styles": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Section-specific styles to avoid.",
            "example": ["crowded arrangement"]
          },
          "duration": {
            "type": "number",
            "minimum": 3,
            "maximum": 120,
            "description": "Section duration in seconds.",
            "example": 25
          },
          "lines": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 200
            },
            "description": "Lyrics lines for this section.",
            "example": ["We cross the night with open eyes", "Cada paso brilla bajo el cielo"]
          }
        }
      },
      "OutputFormat": {
        "type": "string",
        "description": "Output audio format. Formatted as codec_sample_rate_bitrate.",
        "enum": [
          "mp3_22050_32",
          "mp3_44100_32",
          "mp3_44100_64",
          "mp3_44100_96",
          "mp3_44100_128",
          "mp3_44100_192",
          "pcm_8000",
          "pcm_16000",
          "pcm_22050",
          "pcm_24000",
          "pcm_44100",
          "pcm_48000",
          "ulaw_8000",
          "alaw_8000",
          "opus_48000_32",
          "opus_48000_64",
          "opus_48000_96",
          "opus_48000_128",
          "opus_48000_192"
        ],
        "default": "mp3_44100_128",
        "example": "mp3_44100_128"
      },
      "SubmitResponse": {
        "type": "object",
        "required": ["code", "data"],
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "data": {
            "type": "object",
            "required": ["task_id", "status", "created_time"],
            "properties": {
              "task_id": {
                "type": "string",
                "example": "task_xxxxxxxxxxxxxxxx"
              },
              "status": {
                "type": "string",
                "enum": ["not_started"],
                "example": "not_started"
              },
              "created_time": {
                "type": "string",
                "format": "date-time",
                "example": "2026-06-26T10:30:00"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
